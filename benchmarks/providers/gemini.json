{
  "id": "gemini",
  "name": "Gemini API / Google AI Studio",
  "status": "planned",
  "canonical_eligible": false,
  "docs": {
    "pricing": "https://ai.google.dev/gemini-api/docs/pricing",
    "text_generation": "https://ai.google.dev/gemini-api/docs/text-generation",
    "structured_output": "https://ai.google.dev/gemini-api/docs/structured-output",
    "embeddings": "https://ai.google.dev/gemini-api/docs/embeddings",
    "terms": "https://ai.google.dev/gemini-api/terms"
  },
  "auth": {
    "scheme": "api_key_header",
    "env": "GOOGLE_AI_STUDIO_API_KEY",
    "header": "x-goog-api-key",
    "format": "${GOOGLE_AI_STUDIO_API_KEY}",
    "notes": "Use the documented Gemini API key directly. Do not use JWT, OAuth, or OpenAI-compatible assumptions for this benchmark lane."
  },
  "base_url": "https://generativelanguage.googleapis.com/v1beta",
  "tasks": ["chat_json_judgment", "embedding_similarity"],
  "limits": {
    "max_concurrency": 1,
    "requests_per_minute": null,
    "requests_per_day": null,
    "per_run_request_budget": 8
  },
  "data_use": {
    "free_tier_content_used_to_improve_products": true,
    "notes": "Gemini API pricing page says free-tier content is used to improve Google products. Treat free-tier results as benchmark evidence unless a later policy decision allows source-safe canonical usage."
  },
