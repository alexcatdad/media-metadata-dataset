# Media Offline Database local configuration.
# Copy to .env for local/bootstrap runs. Do not commit real secrets.

# Runtime
MOD_ENV=local
MOD_LOG_LEVEL=INFO
MOD_DATA_DIR=.mod/data
MOD_CACHE_DIR=.mod/cache
MOD_OUTPUT_DIR=.mod/out

# Hugging Face publishing.
# Required only when creating/updating dataset repos.
HF_TOKEN=
HF_NAMESPACE=
HF_DATASET_REPO=media-metadata-dataset
# Backwards-compatible aliases still supported if you already have older env keys.
HF_ORG=
HF_DATASET_PREFIX=

# OpenAI-compatible LLM routing.
# OpenRouter is the expected first provider for non-commercial/open-source work.
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_BASE_URL=https://openrouter.ai/api/v1
OPENAI_COMPAT_DEFAULT_MODEL=inclusionai/ling-2.6-flash:free
OPENAI_COMPAT_FALLBACK_MODELS=inclusionai/ling-2.6-1t:free,liquid/lfm-2.5-1.2b-instruct:free,openai/gpt-oss-20b:free,baidu/qianfan-ocr-fast:free
OPENAI_COMPAT_DAILY_REQUEST_BUDGET=500
OPENAI_COMPAT_MAX_CONCURRENCY=2
OPENAI_COMPAT_REQUESTS_PER_MINUTE=30

# Gemini API / Google AI Studio benchmark lanes.
# Free-tier content is used to improve Google products; keep benchmark-only unless policy changes.
GOOGLE_AI_STUDIO_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_BENCHMARK_DELAY_SECONDS=4

# Z.ai free LLM routing.
# Z.ai uses OpenAI-compatible chat completions at the general API endpoint.
# The free GLM Flash lane is constrained by concurrency, so keep this at one.
# Z_AI_API_KEY_SECRET may be either the secret half or the full id.secret API key.
# Requests send Authorization: Bearer <id.secret API key>.
Z_AI_API_KEY_ID=
Z_AI_API_KEY_SECRET=
Z_AI_BASE_URL=https://api.z.ai/api/paas/v4/
Z_AI_DEFAULT_MODEL=glm-4.5-flash
Z_AI_FALLBACK_MODELS=glm-4.7-flash
Z_AI_MAX_CONCURRENCY=1

# Embeddings.
EMBEDDING_BACKEND=cloudflare_workers_ai
EMBEDDING_MODEL=@cf/baai/bge-m3
EMBEDDING_BATCH_SIZE=64
EMBEDDING_DAILY_TOKEN_BUDGET=100000
EMBEDDING_MAX_CONCURRENCY=2

# Cloud embedding providers.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_EMBEDDING_REQUESTS_PER_MINUTE=60
CLOUDFLARE_EMBEDDING_DAILY_NEURON_BUDGET=10000
JINA_API_KEY=
JINA_EMBEDDING_REQUESTS_PER_MINUTE=100
JINA_EMBEDDING_TOKENS_PER_MINUTE=100000
JINA_EMBEDDING_MAX_CONCURRENCY=2
HF_EMBEDDING_PROVIDER=hf-inference
HF_EMBEDDING_REQUESTS_PER_MINUTE=30
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_MULTIMODAL_EMBEDDING_MODEL=gemini-embedding-2
GEMINI_EMBEDDING_REQUESTS_PER_MINUTE=30
OPENROUTER_EMBEDDING_REQUESTS_PER_MINUTE=20
OPENROUTER_EMBEDDING_REQUESTS_PER_DAY=50
OPENROUTER_EMBEDDING_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free

# Optional provider credentials.
# These do not imply redistribution rights; provider policy decides what may be stored.

# Anime / manga providers.
ANIDB_CLIENT_NAME=
ANIDB_CLIENT_VERSION=1
ANIDB_HTTP_REQUESTS_PER_MINUTE=30
ANIDB_TITLE_DUMP_MAX_RUNS_PER_DAY=1
ANILIST_ACCESS_TOKEN=
ANILIST_REQUESTS_PER_MINUTE=30
MAL_CLIENT_ID=
MAL_CLIENT_SECRET=
MAL_REQUESTS_PER_MINUTE=30
KITSU_CLIENT_ID=
KITSU_CLIENT_SECRET=
KITSU_REQUESTS_PER_MINUTE=60
SIMKL_CLIENT_ID=
SIMKL_CLIENT_SECRET=
SIMKL_REQUESTS_PER_MINUTE=60

# Movies / TV providers.
TMDB_READ_ACCESS_TOKEN=
TMDB_API_REQUESTS_PER_SECOND=4
TMDB_DAILY_EXPORT_MAX_RUNS_PER_DAY=1
TVDB_API_KEY=
TVDB_REQUESTS_PER_MINUTE=60
TRAKT_CLIENT_ID=
TRAKT_CLIENT_SECRET=
TRAKT_REQUESTS_PER_MINUTE=60
OMDB_API_KEY=
OMDB_REQUESTS_PER_DAY=1000
JUSTWATCH_TOKEN=
JUSTWATCH_REQUESTS_PER_MINUTE=60

# Open/public sources.
TVMAZE_REQUESTS_PER_10_SECONDS=10
OPENLIBRARY_REQUESTS_PER_SECOND=1
WIKIDATA_DUMP_MAX_RUNS_PER_WEEK=1
MANAMI_RELEASE_MAX_RUNS_PER_DAY=1

# Future/optional domains and relationship evidence.
PODCASTINDEX_API_KEY=
PODCASTINDEX_API_SECRET=
LISTENNOTES_API_KEY=
GOOGLE_BOOKS_API_KEY=
HARDCOVER_API_TOKEN=
ISBNDB_API_KEY=
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=
MOBYGAMES_API_KEY=
GIANTBOMB_API_KEY=

# GitHub.
# Usually not needed in GitHub Actions because GITHUB_TOKEN is injected by Actions.
GITHUB_TOKEN=
